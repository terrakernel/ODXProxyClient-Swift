//
//  TestCredentials.swift  (TEMPLATE)
//
//  Copy this file to `TestCredentials.swift` (same directory) and fill in
//  the values below. The real file is gitignored so your credentials never
//  get committed.
//
//      cp TestCredentials.swift.example TestCredentials.swift
//
//  Tests that need credentials use `try #require(TestCredentials.isConfigured)`
//  to skip when any value is empty/zero, so leaving placeholders in place
//  simply skips the integration tests.
//

import Foundation

enum TestCredentials {
    /// ODX gateway base URL, e.g. "https://gateway.odxproxy.io"
    static let gatewayURL: String = ""

    /// Proxy API key (the `x-api-key` header value)
    static let odxAPIKey: String = ""

    /// Odoo base URL, e.g. "https://erp.example.com"
    static let odooURL: String = ""

    /// Odoo database name
    static let odooDB: String = ""

    /// Odoo user id (integer uid)
    static let odooUserID: Int = 0

    /// Odoo user's API key (NOT the proxy api key)
    static let odooAPIKey: String = ""

    /// True only when every credential is filled in.
    static var isConfigured: Bool {
        !gatewayURL.isEmpty &&
        !odxAPIKey.isEmpty &&
        !odooURL.isEmpty &&
        !odooDB.isEmpty &&
        odooUserID > 0 &&
        !odooAPIKey.isEmpty
    }
}
